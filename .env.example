# Copy to .env.local for local dev, and/or set in the Vercel dashboard.
# Everything here is OPTIONAL: the form backend already works out of the box.

# Form delivery (Formspree)
# The live Formspree form id is committed as a default in lib/forms.ts
# (a form id is a public value, so this is safe). The forms work on every
# deploy with no config. Set these only to override that default, for example
# a separate production form or split quote/contact inboxes.
# NEXT_PUBLIC_FORMSPREE_FORM_ID=
# NEXT_PUBLIC_FORMSPREE_QUOTE_ID=
# NEXT_PUBLIC_FORMSPREE_CONTACT_ID=
