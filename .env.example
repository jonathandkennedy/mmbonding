# Copy to .env.local for local dev, and set the same in the Vercel dashboard.

# ── Form delivery (Formspree) ──────────────────────────────────────────────
# Create forms at https://formspree.io and paste the form hashid (the part
# after /f/ in your endpoint, e.g. https://formspree.io/f/abcdwxyz -> abcdwxyz).
# A single shared form works; separate quote/contact forms let you route them
# to different inboxes. Specific ids win over the shared fallback.
NEXT_PUBLIC_FORMSPREE_FORM_ID=
# NEXT_PUBLIC_FORMSPREE_QUOTE_ID=
# NEXT_PUBLIC_FORMSPREE_CONTACT_ID=
